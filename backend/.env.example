# Copy this file to `.dev.vars` for local development (`wrangler dev` reads it).
# For production, set secrets instead, e.g.:
#   npx wrangler secret put GEMINI_API_KEY
#
# Never commit real keys. `.dev.vars` and `.env` are gitignored.

# Default provider is Gemini (free tier). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Only needed if you set LLM_PROVIDER=anthropic in wrangler.toml.
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: enables the "Shop ingredients" button. Get a key from the Instacart
# Developer Platform (https://docs.instacart.com/developer_platform_api).
# INSTACART_API_KEY=your-instacart-key-here
